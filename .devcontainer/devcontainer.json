{
  "name": "Bun + Gemini (Lightweight Ubuntu)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/bun:1": {}
  },
  "portsAttributes": {
    "3000": {
      "label": "Application",
      "visibility": "public"
    }
  },
  "forwardPorts": [3000],
  "postCreateCommand": "bun install -g @google/gemini-cli",
  "postStartCommand": "nohup bun x serve docs -p 3000 > /dev/null 2>&1 &",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
