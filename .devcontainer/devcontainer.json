{
  "name": "Mobile Dev Box",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers-contrib/features/bun:1": {}
  },

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Server",
      "onAutoForward": "openBrowser",
      "visibility": "public" 
    }
  },
  "postCreateCommand": "bun install -g @google/gemini-cli && nohup bun x serve ./docs --port 3000 > /tmp/bun-serve.log 2>&1 &",

  "remoteUser": "codespace"
}
