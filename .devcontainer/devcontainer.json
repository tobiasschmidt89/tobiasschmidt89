{
  "name": "Bun + Gemini",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "portsAttributes": {
    "3000": { "label": "Application", "visibility": "public" },
    "2222": { "label": "SSH", "visibility": "private" }
  },
  "forwardPorts": [3000, 2222],
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y unzip && curl -fsSL https://bun.sh/install | bash && /home/vscode/.bun/bin/bun install -g @google/gemini-cli",
  "postStartCommand": "nohup /home/vscode/.bun/bin/bun x serve docs -p 3000 > /dev/null 2>&1 &",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.bun/bin",
    "BUN_INSTALL": "/home/vscode/.bun"
  }
}
