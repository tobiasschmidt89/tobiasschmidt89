{
  "name": "Bun Alpine Native",
  "image": "oven/bun:alpine",
  "remoteUser": "root",
  "updateContentCommand": "apk add --no-cache git curl openssh-client github-cli",
  "postCreateCommand": "bun install -g @google/gemini-cli",
  "postStartCommand": "nohup bun x serve /docs --port 3000 > /dev/null 2>&1 &",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Docs Server",
      "visibility": "public",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "ash"
      }
    }
  }
}
