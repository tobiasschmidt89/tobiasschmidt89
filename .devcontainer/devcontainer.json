{
  "name": "Bun Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "postStartCommand": "nohup bun x serve docs > /dev/null 2>&1 &",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Docs Server",
      "visibility": "public",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["oven.bun-vscode"]
    }
  }
}
