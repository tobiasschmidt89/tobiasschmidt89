{
  "name": "Bun Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "root",
  "postStartCommand": "nohup bun x serve /docs --port 3000 > /dev/null 2>&1 &",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Docs Server",
      "visibility": "public",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode"
      ]
    }
  }
}
